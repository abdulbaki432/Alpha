{
  "expo": {
    "name": "Alpha - AI Call Assistant",
    "slug": "alpha-ai-call-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-av",
      [
        "expo-contacts",
        {
          "contactsPermission": "Alpha uses your contacts to greet known callers by name."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Alpha saves call recordings to your media library.",
          "saveToPhotostream": false,
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
